# ============================================================
# .env.example — Dr. Jaspal Singh Website
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to Git.
# ============================================================

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://username:password@localhost:5432/jaspalsingh_db

# --- Cloudinary (PDF & image storage) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- JWT Authentication (admin login) ---
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# --- Admin Credentials ---
ADMIN_EMAIL=admin@jaspalsingh.in
ADMIN_PASSWORD=choose_a_strong_password_here

# --- Nodemailer (Gmail SMTP for contact form alerts) ---
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_character_gmail_app_password
ADMIN_NOTIFICATION_EMAIL=the_email_where_you_want_contact_alerts

# --- App Config ---
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500
