# ============================================================
# .env.example — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL (Supabase) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# --- Admin Login ---
ADMIN_EMAIL=jaspal@jaspalsingh.in
ADMIN_PASSWORD=YourStrongAdminPassword123!

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Gmail SMTP (Nodemailer) ---
# Use a Google App Password, NOT your regular Gmail password
# Get it at: myaccount.google.com → Security → App passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_NOTIFICATION_EMAIL=jaspal@jaspalsingh.in

# --- Cashfree Payment Gateway ---
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# --- OMR Test Checker (admin-only bubble-sheet grading) ---
# URL of the separate omr-service (Python/Flask/OpenCV) Render deployment
OMR_SERVICE_URL=https://jaspalsingh-omr-service.onrender.com
# Shared secret - must match OMR_SERVICE_SECRET set on the omr-service deployment
OMR_SERVICE_SECRET=generate_a_random_string_and_set_on_both_services
# Google Sheets service account (Sheets API), used to push OMR results.
# Share your results spreadsheet with this service account's email as Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=omr-sheets-writer@yourproject.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --- App ---
PORT=5000
NODE_ENV=production
BACKEND_URL=https://jaspalsingh-backend.onrender.com
# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://jaspalsingh.in,https://www.jaspalsingh.in
