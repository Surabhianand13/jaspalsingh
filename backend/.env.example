# ============================================================
# .env.example — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- PostgreSQL (Supabase) ---
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres

# --- JWT ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# --- Admin Login ---
ADMIN_EMAIL=jaspal@jaspalsingh.in
ADMIN_PASSWORD=YourStrongAdminPassword123!

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Gmail SMTP (Nodemailer) ---
# Use a Google App Password, NOT your regular Gmail password
# Get it at: myaccount.google.com → Security → App passwords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_NOTIFICATION_EMAIL=jaspal@jaspalsingh.in

# --- App ---
PORT=5000
NODE_ENV=production
# Comma-separated list of allowed frontend origins
FRONTEND_URL=https://jaspalsingh.in,https://www.jaspalsingh.in
