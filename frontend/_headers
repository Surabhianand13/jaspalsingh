# Cloudflare Pages security headers.
# Only Cloudflare's edge honours this file (not the local static server),
# so verify these on jaspalsingh.in after merge - see CLAUDE.md.
#
# IMPORTANT: keep this to a single "/*" block. Cloudflare Pages does NOT
# override a header when a more specific path pattern also matches - it
# sends BOTH header instances. For most headers that's harmless, but for
# Content-Security-Policy specifically, browsers enforce every CSP header
# present as an intersection (AND), so a second, narrower block can only
# ever make the effective policy stricter, never more permissive. A
# previous version of this file had a looser CSP under /checkout/* that
# was silently vetoed by this block's script-src, breaking Turnstile (and
# therefore every checkout) site-wide - do not reintroduce a second
# Content-Security-Policy block.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(self "https://checkout.razorpay.com")
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://checkout.razorpay.com https://challenges.cloudflare.com https://cdn.jsdelivr.net https://cdn.quilljs.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.quilljs.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: https:; connect-src 'self' https://jaspalsingh.onrender.com https://*.razorpay.com https://challenges.cloudflare.com; frame-src 'self' https://*.razorpay.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.razorpay.com; frame-ancestors 'self'
